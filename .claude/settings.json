{
  "project": {
    "name": "claude-supervisor",
    "description": "Superviseur de sessions Claude Code avec dashboard web",
    "version": "1.0.0"
  },
  "agents": {
    "defaultModel": "claude-sonnet-4-5-20250929",
    "supervisorModel": "claude-opus-4-6",
    "maxConcurrentAgents": 5
  },
  "dashboard": {
    "refreshInterval": 2000,
    "maxSessionHistory": 50
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/post-tool-reporter.js"
          }
        ]
      }
    ]
  }
}
