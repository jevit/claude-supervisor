{
  "name": "claude-supervisor-dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:unit": "vitest run --config vitest.config.js",
    "test:unit:watch": "vitest --config vitest.config.js",
    "test:unit:coverage": "vitest run --config vitest.config.js --coverage",
    "test:integration": "vitest run --config vitest.integration.config.js",
    "test:integration:coverage": "vitest run --config vitest.integration.config.js --coverage",
    "test:all": "npm run test:unit && npm run test:integration",
    "test:coverage": "npm run test:unit:coverage && npm run test:integration:coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "recharts": "^3.8.0",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^2.1.0",
    "@vitejs/plugin-react": "^4.2.1",
    "jsdom": "^24.1.0",
    "vite": "^5.0.10",
    "vitest": "^2.1.0"
  }
}
