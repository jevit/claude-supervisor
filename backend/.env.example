PORT=3001
NODE_ENV=development

# Optionnel : cle Anthropic si tu veux que le supervisor spawne des agents via SDK
# ANTHROPIC_API_KEY=sk-ant-...

# Nombre maximum d'events conserves en memoire dans EventLog
MAX_EVENTS=2000

# Debounce de persistance JSON (ms) - evite les ecritures trop frequentes
STORE_DEBOUNCE_MS=500

# Repertoire cible des git worktrees (cree automatiquement par les squads)
# Par defaut : sibling du repo (C:/Perso/Workspace3/cs-worktrees)
# WORKTREES_DIR=C:/Perso/Workspace3/cs-worktrees
